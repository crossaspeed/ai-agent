# Database
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_PASSWORD=replace-with-a-strong-app-password

# Redis
REDIS_PASSWORD=
REDIS_DATABASE=1

# LLM
CHAT_MODEL_BASE_URL=https://api.deepseek.com
CHAT_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# Embedding
EMBEDDING_BASE_URL=https://aihubmix.com/v1
EMBEDDING_API_KEY=replace-with-your-embedding-api-key

# Pinecone
PINECONE_API_KEY=replace-with-your-pinecone-api-key
PINECONE_INDEX_NAME=agent-index

# Feishu
FEISHU_APP_ID=replace-with-feishu-app-id
FEISHU_APP_SECRET=replace-with-feishu-app-secret
FEISHU_BOT_OPEN_ID=
FEISHU_CALLBACK_TOKEN=
FEISHU_LONG_CONNECTION_ENABLED=true
FEISHU_LONG_CONNECTION_WORKER_THREADS=2

# Scheduler
SCHEDULER_REMINDER_FIXED_DELAY_MS=60000

# Reminder Redis Queue
REMINDER_REDIS_ENABLED=true
REMINDER_REDIS_BOOTSTRAP_ON_STARTUP=true
REMINDER_REDIS_BOOTSTRAP_BATCH_SIZE=1000
REMINDER_REDIS_POLL_LIMIT=100
REMINDER_REDIS_PROCESSING_TIMEOUT_MS=120000
REMINDER_REDIS_RETRY_DELAY_MS=15000
REMINDER_REDIS_KEY_PREFIX=reminder
